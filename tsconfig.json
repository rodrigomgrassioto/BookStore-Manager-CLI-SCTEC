{
  "compilerOptions": {
    "target": "es2024", // prof ped 2020+
    "module": "commonjs", // solicitado pelo prof
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"]
}
